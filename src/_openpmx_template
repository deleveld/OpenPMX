FILE="${1}"
DATA="${2:-}"

# control, object, and executable
BASE=$(basename "${FILE}")
OBJFILE="${BASE}.o"
EXECFILE="${FILE}.bin"

# setup the queue
MYPID=$$
MYTICKET=$(date +%s%N)-$MYPID
mkdir -p "$QUEUEDIR"
touch "$QUEUEDIR/$MYTICKET"

LAST_REPORTED_RANK=-1
while true; do
	# find my rank in the queue
    ALL_TICKETS=$(ls -1 "$QUEUEDIR" | sort)
    OLDEST_TICKET=$(echo "$ALL_TICKETS" | head -n 1)
    MY_RANK=$(echo "$ALL_TICKETS" | grep -n "^${MYTICKET}$" | cut -d: -f1)

	# if rank gets lost, remake it
    if [ -z "$MY_RANK" ]; then
        echo "queue: ticket lost, re-entering"
        touch "$QUEUEDIR/$MYTICKET"
        continue
    fi

	# report rank if changed
    if [ "$MY_RANK" -ne "$LAST_REPORTED_RANK" ] && [ "$MY_RANK" -gt 1 ]; then
        echo "queue: rank is $MY_RANK"
        LAST_REPORTED_RANK=$MY_RANK
    fi

	# is it our turn to run
    if [ "$OLDEST_TICKET" = "$MYTICKET" ]; then
        break
    fi

	# find stale tickets and remove
    LEADER_PID=${OLDEST_TICKET##*-}
    if ! kill -0 "$LEADER_PID" 2>/dev/null; then
        echo "queue: removing stale $QUEUEDIR/$OLDEST_TICKET"
        rm -f "$QUEUEDIR/$OLDEST_TICKET"
        continue
    fi

    sleep 2
done

# cleanup when done
EXITMESSAGE="error: openpmx failed\n"
cleanup() {
	printf "${EXITMESSAGE}" || true
	rm "${OBJFILE}" || true
	rm "${EXECFILE}" || true
	rm -f "$QUEUEDIR/$MYTICKET" || true
}
trap cleanup EXIT

# Set platform-specific variables
if [[ "$PLATFORM" == "msys2" ]]; then
	EXECFILE="${FILE}.exe"
fi

# translate control file to C code
if [ "${FILE##*.}" != "c" ]; then
	"${OPENPMXPATH}/bin/openpmxtran" "${FILE}" "${DATA}" 2>&1
	FILE="${FILE}.c"
fi

# compile the C code
# only show relative paths
(${CC} ${CFLAGS} -fdebug-prefix-map=$(pwd)=. -I"${OPENPMXPATH}/include" -c "${FILE}" -o "${OBJFILE}") 2>&1

# we have object files, so link now
(${CC} "${OBJFILE}" -o "${EXECFILE}" -L"${OPENPMXPATH}/lib" ${LFLAGS} -lopenpmx -lgsl -lgslcblas -lm) 2>&1

# execute and clear exit message
if "./${EXECFILE}" 2>&1; then
	EXITMESSAGE=""
fi
